const express = require("express");
const multer = require("multer");
const cors = require("cors");
const fs = require("fs");
const path = require("path");

const app = express();

app.use(cors());

// =====================
// CONFIG
// =====================

const API_KEY = "sh202620252009sh";

const UPLOAD_PATH = "/var/www/storage/uploads";
const BASE_URL = "https://storage.lootops.me/uploads";

// =====================
// IMPORTANT FIX (THIS WAS MISSING)
// =====================
app.use("/uploads", express.static(UPLOAD_PATH));

// =====================
// AUTH MIDDLEWARE
// =====================
function checkAuth(req, res, next) {
  const token = req.headers.authorization;

  if (!token || token !== API_KEY) {
    return res.status(403).json({ error: "Unauthorized" });
  }

  next();
}

// =====================
// MULTER STORAGE
// =====================
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    cb(null, UPLOAD_PATH);
  },

  filename: (req, file, cb) => {
    const safeName = file.originalname.replace(/[^a-zA-Z0-9.\-_]/g, "_");
    cb(null, Date.now() + "-" + safeName);
  },
});

const upload = multer({
  storage: storage,
  limits: {
    fileSize: 20 * 1024 * 1024, // 20MB
  },
});

// =====================
// ROUTES
// =====================

// Upload file
app.post("/upload", checkAuth, upload.single("file"), (req, res) => {
  if (!req.file) {
    return res.status(400).json({ error: "No file uploaded" });
  }

  res.json({
    url: `${BASE_URL}/${req.file.filename}`,
    filename: req.file.filename,
    size: req.file.size,
    type: req.file.mimetype,
  });
});

// List files
app.get("/files", (req, res) => {
  fs.readdir(UPLOAD_PATH, (err, files) => {
    if (err) {
      return res.status(500).json({ error: "Cannot read files" });
    }

    res.json({ files });
  });
});

// Health check
app.get("/", (req, res) => {
  res.send("Storage server running successfully 🚀");
});

// =====================
// START SERVER
// =====================
app.listen(5000, "0.0.0.0", () => {
  console.log("🚀 Server running on port 5000");
});
